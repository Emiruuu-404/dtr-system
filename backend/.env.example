# Django Deployment Settings

# Change DEBUG to False for production!
DEBUG=True

# Provide a long random string here for security (keep it secret)
SECRET_KEY=django-insecure-your-secret-key-replace-me

# Comma-separated list of hostnames/IPs your backend will be accessible on (e.g., mysite.com,api.mysite.com)
# Use * ONLY for local development or testing.
ALLOWED_HOSTS=*

# Set to False once you configure CORS_ALLOWED_ORIGINS below.
CORS_ALLOW_ALL_ORIGINS=True

# Comma-separated list of your frontend URLs (e.g., https://my-frontend-vercel.app)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
